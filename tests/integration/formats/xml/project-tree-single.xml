<?xml version="1.0" encoding="UTF-8"?>
<class>
  <public/>
  class
  <name>Calculator</name>
  <body>
    {
    <method>
      <public/>
      <returns>
        <type>int</type>
      </returns>
      <name>Add</name>
      <parameters>
        (
        <parameter>
          <type>int</type>
          <name>a</name>
        </parameter>
        ,
        <parameter>
          <type>int</type>
          <name>b</name>
        </parameter>
        )
      </parameters>
      <body>
        <block>
          {
          <return>
            return
            <binary>
              <op>
                <plus/>
                +
              </op>
              <left>
                <ref>a</ref>
              </left>
              +
              <right>
                <ref>b</ref>
              </right>
            </binary>
            ;
          </return>
          }
        </block>
      </body>
    </method>
    <method>
      <public/>
      <returns>
        <type>int</type>
      </returns>
      <name>Subtract</name>
      <parameters>
        (
        <parameter>
          <type>int</type>
          <name>a</name>
        </parameter>
        ,
        <parameter>
          <type>int</type>
          <name>b</name>
        </parameter>
        )
      </parameters>
      <body>
        <block>
          {
          <return>
            return
            <binary>
              <op>
                <minus/>
                -
              </op>
              <left>
                <ref>a</ref>
              </left>
              -
              <right>
                <ref>b</ref>
              </right>
            </binary>
            ;
          </return>
          }
        </block>
      </body>
    </method>
    <method>
      <public/>
      <returns>
        <type>int</type>
      </returns>
      <name>Multiply</name>
      <parameters>
        (
        <parameter>
          <type>int</type>
          <name>a</name>
        </parameter>
        ,
        <parameter>
          <type>int</type>
          <name>b</name>
        </parameter>
        )
      </parameters>
      <body>
        <block>
          {
          <return>
            return
            <binary>
              <op>
                <multiply/>
                *
              </op>
              <left>
                <ref>a</ref>
              </left>
              *
              <right>
                <ref>b</ref>
              </right>
            </binary>
            ;
          </return>
          }
        </block>
      </body>
    </method>
    }
