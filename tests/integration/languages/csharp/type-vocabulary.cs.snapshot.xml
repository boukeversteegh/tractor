<?xml version="1.0" encoding="UTF-8"?>
<unit>
  <comment>// Principle #14: type references wrap their name in a &lt;name&gt; child.
// Covers: plain types, generic types, base list (extends + implements),
// type parameter declarations.</comment>
  <import>
    using
    <qualified_name>
      <qualified_name>
        <name>System</name>
        .
        <name>
          <name>Collections</name>
        </name>
      </qualified_name>
      .
      <name>
        <name>Generic</name>
      </name>
    </qualified_name>
    ;
  </import>
  <interface>
    <internal/>
    interface
    <name>IBarker</name>
    <body>
      {
      <method>
        <public/>
        <returns>
          <type>
            <name>void</name>
          </type>
        </returns>
        <name>Bark</name>
        ();
      </method>
      }
    </body>
  </interface>
  <class>
    <internal/>
    class
    <name>Animal</name>
    <body>{}</body>
  </class>
  <class>
    <internal/>
    class
    <name>Dog</name>
    &lt;
    <generic>
      <name>T</name>
    </generic>
    &gt;
    <extends>
      :
      <type>
        <name>Animal</name>
      </type>
      ,
      <type>
        <name>IBarker</name>
      </type>
    </extends>
    <type_parameter_constraints_clause>
      where
      <name>T</name>
      :
      <type_parameter_constraint>
        <type>
          <name>Animal</name>
        </type>
      </type_parameter_constraint>
    </type_parameter_constraints_clause>
    <body>
      {
      <field>
        <public/>
        <variable>
          <type>
            <name>T</name>
          </type>
          <declarator>
            <name>Owner</name>
          </declarator>
        </variable>
        ;
      </field>
      <field>
        <public/>
        <variable>
          <type>
            <generic/>
            List&lt;
            <type>
              <name>string</name>
            </type>
            &gt;
          </type>
          <declarator>
            <name>Tags</name>
          </declarator>
        </variable>
        ;
      </field>
      <method>
        <public/>
        <returns>
          <type>
            <name>void</name>
          </type>
        </returns>
        <name>Bark</name>
        ()
        <body>
          <block>{}</block>
        </body>
      </method>
      }
    </body>
  </class>
</unit>
