<?xml version="1.0" encoding="UTF-8"?>
<unit>
  <comment>// Principle #12: parameters / arguments / generics / accessors render as
// flat siblings with field attributes. No &lt;parameters&gt;/&lt;accessor_list&gt;
// wrapper nesting.</comment>
  <class>
    <internal/>
    class
    <name>FlatLists</name>
    <body>
      {
      <method>
        <public/>
        <returns>
          <name>T</name>
        </returns>
        <name>First</name>
        &lt;
        <generic>
          <name>T</name>
        </generic>
        ,
        <generic>
          <name>U</name>
        </generic>
        &gt;(
        <parameter>
          <type>
            <name>T</name>
          </type>
          <name>a</name>
        </parameter>
        ,
        <parameter>
          <type>
            <name>U</name>
          </type>
          <name>b</name>
        </parameter>
        ,
        <parameter>
          <type>
            <name>int</name>
          </type>
          <name>c</name>
        </parameter>
        )
        <type_parameter_constraints_clause>
          where
          <name>T</name>
          :
          <type_parameter_constraint>class</type_parameter_constraint>
        </type_parameter_constraints_clause>
        <body>
          <block>
            {
            <return>
              return
              <name>a</name>
              ;
            </return>
            }
          </block>
        </body>
      </method>
      <property>
        <public/>
        <type>
          <name>int</name>
        </type>
        <name>Count</name>
        {
        <accessor>
          <get/>
        </accessor>
        <accessor>
          <set/>
        </accessor>
        }
      </property>
      <method>
        <public/>
        <returns>
          <type>
            <name>void</name>
          </type>
        </returns>
        <name>Caller</name>
        ()
        <body>
          <block>
            {
            <expression>
              <call>
                <type>
                  <generic/>
                  First&lt;
                  <type>
                    <name>string</name>
                  </type>
                  ,
                  <type>
                    <name>int</name>
                  </type>
                  &gt;
                </type>
                (
                <argument>
                  <string>
                    &quot;
                    <string_literal_content>x</string_literal_content>
                    &quot;
                  </string>
                </argument>
                ,
                <argument>
                  <int>1</int>
                </argument>
                ,
                <argument>
                  <int>2</int>
                </argument>
                )
              </call>
              ;
            </expression>
            }
          </block>
        </body>
      </method>
      }
    </body>
  </class>
</unit>
