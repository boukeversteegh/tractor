<?xml version="1.0" encoding="UTF-8"?>
<unit>
  <comment>// Conditional shape: flat &lt;if&gt;/&lt;else_if&gt;/&lt;else&gt;. Ternary keeps
// &lt;then&gt;/&lt;else&gt; via surgical wrap.</comment>
  <class>
    <internal/>
    class
    <name>Conditionals</name>
    <body>
      {
      <method>
        <public/>
        <returns>
          <type>
            <name>string</name>
          </type>
        </returns>
        <name>Classify</name>
        (
        <parameter>
          <type>
            <name>int</name>
          </type>
          <name>n</name>
        </parameter>
        )
        <body>
          <block>
            {
            <if>
              if (
              <condition>
                <binary>
                  <op>
                    <compare>
                      <less/>
                    </compare>
                    &lt;
                  </op>
                  <left>
                    <name>n</name>
                  </left>
                  &lt;
                  <right>
                    <int>0</int>
                  </right>
                </binary>
              </condition>
              )
              <then>
                <block>
                  {
                  <return>
                    return
                    <string>
                      &quot;
                      <string_literal_content>neg</string_literal_content>
                      &quot;
                    </string>
                    ;
                  </return>
                  }
                </block>
              </then>
              else
              <if>
                if (
                <condition>
                  <binary>
                    <op>
                      <equals/>
                      ==
                    </op>
                    <left>
                      <name>n</name>
                    </left>
                    ==
                    <right>
                      <int>0</int>
                    </right>
                  </binary>
                </condition>
                )
                <then>
                  <block>
                    {
                    <return>
                      return
                      <string>
                        &quot;
                        <string_literal_content>zero</string_literal_content>
                        &quot;
                      </string>
                      ;
                    </return>
                    }
                  </block>
                </then>
                else
                <if>
                  if (
                  <condition>
                    <binary>
                      <op>
                        <compare>
                          <less/>
                        </compare>
                        &lt;
                      </op>
                      <left>
                        <name>n</name>
                      </left>
                      &lt;
                      <right>
                        <int>10</int>
                      </right>
                    </binary>
                  </condition>
                  )
                  <then>
                    <block>
                      {
                      <return>
                        return
                        <string>
                          &quot;
                          <string_literal_content>small</string_literal_content>
                          &quot;
                        </string>
                        ;
                      </return>
                      }
                    </block>
                  </then>
                  else
                  <block>
                    {
                    <return>
                      return
                      <string>
                        &quot;
                        <string_literal_content>big</string_literal_content>
                        &quot;
                      </string>
                      ;
                    </return>
                    }
                  </block>
                </if>
              </if>
            </if>
            }
          </block>
        </body>
      </method>
      <method>
        <public/>
        <returns>
          <type>
            <name>string</name>
          </type>
        </returns>
        <name>Label</name>
        (
        <parameter>
          <type>
            <name>int</name>
          </type>
          <name>n</name>
        </parameter>
        )
        <body>
          =&gt;
          <ternary>
            <condition>
              <binary>
                <op>
                  <compare>
                    <greater/>
                  </compare>
                  &gt;
                </op>
                <left>
                  <name>n</name>
                </left>
                &gt;
                <right>
                  <int>0</int>
                </right>
              </binary>
            </condition>
            ?
            <then>
              <string>
                &quot;
                <string_literal_content>positive</string_literal_content>
                &quot;
              </string>
            </then>
            :
            <else>
              <string>
                &quot;
                <string_literal_content>non-positive</string_literal_content>
                &quot;
              </string>
            </else>
          </ternary>
        </body>
        ;
      </method>
      }
    </body>
  </class>
</unit>
