<?xml version="1.0" encoding="UTF-8"?>
<unit>
  <comment>// Property accessor lists flatten: get/set are direct siblings of the
// &lt;property&gt;, not nested inside an &lt;accessor_list&gt; wrapper.</comment>
  <class>
    <internal/>
    class
    <name>Accessors</name>
    <body>
      {
      <property>
        <public/>
        <type>
          <name>int</name>
        </type>
        <name>AutoProp</name>
        {
        <accessor>get;</accessor>
        <accessor>set;</accessor>
        }
      </property>
      <field>
        <private/>
        <variable>
          <type>
            <name>int</name>
          </type>
          <declarator>
            <name>_backing</name>
          </declarator>
        </variable>
        ;
      </field>
      <property>
        <public/>
        <type>
          <name>int</name>
        </type>
        <name>Manual</name>
        {
        <accessor>
          get
          <body>
            <block>
              {
              <return>
                return
                <name>_backing</name>
                ;
              </return>
              }
            </block>
          </body>
        </accessor>
        <accessor>
          set
          <body>
            <block>
              {
              <expression_statement>
                <assign>
                  <op>=</op>
                  <left>
                    <name>_backing</name>
                  </left>
                  =
                  <right>
                    <name>value</name>
                  </right>
                </assign>
                ;
              </expression_statement>
              }
            </block>
          </body>
        </accessor>
        }
      </property>
      <property>
        <public/>
        <type>
          <name>int</name>
        </type>
        <name>ReadOnly</name>
        {
        <accessor>get;</accessor>
        }
      </property>
      <property>
        <public/>
        <type>
          <name>int</name>
        </type>
        <name>WriteOnly</name>
        {
        <accessor>
          set
          <body>
            <block>
              {
              <expression_statement>
                <assign>
                  <op>=</op>
                  <left>
                    <name>_backing</name>
                  </left>
                  =
                  <right>
                    <name>value</name>
                  </right>
                </assign>
                ;
              </expression_statement>
              }
            </block>
          </body>
        </accessor>
        }
      </property>
      }
    </body>
  </class>
</unit>
