<?xml version="1.0" encoding="UTF-8"?>
<program>
  <line_comment>// Conditional shape: flat &lt;if&gt;/&lt;else_if&gt;/&lt;else&gt;. Ternary keeps</line_comment>
  <line_comment>// &lt;then&gt;/&lt;else&gt; via surgical wrap.</line_comment>
  <class>
    <package/>
    class
    <name>Conditionals</name>
    <body>
      {
      <method>
        <package/>
        <returns>
          <type>
            <name>String</name>
          </type>
        </returns>
        <name>classify</name>
        (
        <param>
          <type>
            <name>int</name>
          </type>
          <name>n</name>
        </param>
        )
        <body>
          {
          <if>
            if
            <condition>
              <parenthesized_expression>
                (
                <binary>
                  <op>
                    <compare>
                      <less/>
                    </compare>
                    &lt;
                  </op>
                  <left>
                    <name>n</name>
                  </left>
                  &lt;
                  <right>
                    <int>0</int>
                  </right>
                </binary>
                )
              </parenthesized_expression>
            </condition>
            <then>
              {
              <return>
                return
                <string>
                  &quot;
                  <string_fragment>neg</string_fragment>
                  &quot;
                </string>
                ;
              </return>
              }
            </then>
            else
            <if>
              if
              <condition>
                <parenthesized_expression>
                  (
                  <binary>
                    <op>
                      <equals/>
                      ==
                    </op>
                    <left>
                      <name>n</name>
                    </left>
                    ==
                    <right>
                      <int>0</int>
                    </right>
                  </binary>
                  )
                </parenthesized_expression>
              </condition>
              <then>
                {
                <return>
                  return
                  <string>
                    &quot;
                    <string_fragment>zero</string_fragment>
                    &quot;
                  </string>
                  ;
                </return>
                }
              </then>
              else
              <if>
                if
                <condition>
                  <parenthesized_expression>
                    (
                    <binary>
                      <op>
                        <compare>
                          <less/>
                        </compare>
                        &lt;
                      </op>
                      <left>
                        <name>n</name>
                      </left>
                      &lt;
                      <right>
                        <int>10</int>
                      </right>
                    </binary>
                    )
                  </parenthesized_expression>
                </condition>
                <then>
                  {
                  <return>
                    return
                    <string>
                      &quot;
                      <string_fragment>small</string_fragment>
                      &quot;
                    </string>
                    ;
                  </return>
                  }
                </then>
                else {
                <return>
                  return
                  <string>
                    &quot;
                    <string_fragment>big</string_fragment>
                    &quot;
                  </string>
                  ;
                </return>
                }
              </if>
            </if>
          </if>
          }
        </body>
      </method>
      <method>
        <package/>
        <returns>
          <type>
            <name>String</name>
          </type>
        </returns>
        <name>label</name>
        (
        <param>
          <type>
            <name>int</name>
          </type>
          <name>n</name>
        </param>
        )
        <body>
          {
          <return>
            return
            <ternary>
              <condition>
                <binary>
                  <op>
                    <compare>
                      <greater/>
                    </compare>
                    &gt;
                  </op>
                  <left>
                    <name>n</name>
                  </left>
                  &gt;
                  <right>
                    <int>0</int>
                  </right>
                </binary>
              </condition>
              ?
              <then>
                <string>
                  &quot;
                  <string_fragment>positive</string_fragment>
                  &quot;
                </string>
              </then>
              :
              <else>
                <string>
                  &quot;
                  <string_fragment>non-positive</string_fragment>
                  &quot;
                </string>
              </else>
            </ternary>
            ;
          </return>
          }
        </body>
      </method>
      }
    </body>
  </class>
</program>
