<?xml version="1.0" encoding="UTF-8"?>
<program>
  <line_comment>// Modifiers lifted as empty markers on the declaration. Every access</line_comment>
  <line_comment>// modifier is exhaustive — private/package-private show up explicitly.</line_comment>
  <class>
    <package/>
    class
    <name>Modifiers</name>
    <body>
      {
      <field>
        <final/>
        <static/>
        <public/>
        <type>
          <name>int</name>
        </type>
        <variable_declarator>
          <name>PUB</name>
          =
          <value>
            <int>1</int>
          </value>
        </variable_declarator>
        ;
      </field>
      <field>
        <private/>
        <type>
          <name>int</name>
        </type>
        <variable_declarator>
          <name>priv</name>
          =
          <value>
            <int>2</int>
          </value>
        </variable_declarator>
        ;
      </field>
      <field>
        <protected/>
        <type>
          <name>int</name>
        </type>
        <variable_declarator>
          <name>prot</name>
          =
          <value>
            <int>3</int>
          </value>
        </variable_declarator>
        ;
      </field>
      <field>
        <package/>
        <type>
          <name>int</name>
        </type>
        <variable_declarator>
          <name>pkg</name>
          =
          <value>
            <int>4</int>
          </value>
        </variable_declarator>
        ;
      </field>
      <line_comment>// implicit package-private -&gt; &lt;package/&gt;</line_comment>
      <method>
        <synchronized/>
        <public/>
        <returns>
          <type>
            <name>void</name>
          </type>
        </returns>
        <name>sync</name>
        ()
        <body>{}</body>
      </method>
      <class>
        <static/>
        <abstract/>
        <public/>
        class
        <name>AbsStatic</name>
        <body>{}</body>
      </class>
      }
    </body>
  </class>
</program>
