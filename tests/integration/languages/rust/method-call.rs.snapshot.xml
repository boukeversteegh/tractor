<file>
  <line_comment>// Both function calls and method calls render as &lt;call&gt;. Method calls</line_comment>
  <line_comment>// are distinguished by a &lt;member&gt; child that names the receiver and method.</line_comment>
  <function>
    <private/>
    fn
    <name>use_calls</name>
    ()
    <body>
      {
      <let>
        let
        <name>v</name>
        :
        <type>
          <generic/>
          <name>Vec</name>
          &lt;
          <type>
            <name>i32</name>
          </type>
          &gt;
        </type>
        =
        <value>
          <call>
            <path>
              <name>Vec</name>
              ::
              <name>new</name>
            </path>
            ()
          </call>
        </value>
        ;
      </let>
      <let>
        let
        <name>n</name>
        =
        <value>
          <call>
            <field>
              <value>
                <name>v</name>
              </value>
              .
              <name>len</name>
            </field>
            ()
          </call>
        </value>
        ;
      </let>
      <let>
        let
        <name>s</name>
        =
        <value>
          <call>
            <field>
              <value>
                <string>
                  &quot;
                  <string_content>hi</string_content>
                  &quot;
                </string>
              </value>
              .
              <name>to_string</name>
            </field>
            ()
          </call>
        </value>
        ;
      </let>
      <call>
        <field>
          <value>
            <name>s</name>
          </value>
          .
          <name>to_uppercase</name>
        </field>
        ()
      </call>
      ;
      <macro>
        <name>format</name>
        !
        <token_tree>
          (
          <string>
            &quot;
            <string_content>{}</string_content>
            &quot;
          </string>
          ,
          <int>1</int>
          )
        </token_tree>
      </macro>
      ;
}
    </body>
  </function>
