<?xml version="1.0" encoding="UTF-8"?>
<file>
  <line_comment>// Conditional shape: `else if` chain collapses to flat &lt;else_if&gt;</line_comment>
  <line_comment>// siblings. Ternary via if-expression keeps &lt;then&gt;/&lt;else&gt;.</line_comment>
  <function>
    <private/>
    fn
    <name>classify</name>
    (
    <param>
      <name>n</name>
      :
      <type>
        <name>i32</name>
      </type>
    </param>
    ) -&gt;
    <returns>
      <type>
        <borrowed/>
        &amp;
        <lifetime>
          '
          <name>static</name>
        </lifetime>
        <type>
          <name>str</name>
        </type>
      </type>
    </returns>
    <body>
      {
      <if>
        if
        <condition>
          <binary>
            <op>
              <compare>
                <less/>
              </compare>
              &lt;
            </op>
            <left>
              <name>n</name>
            </left>
            &lt;
            <right>
              <int>0</int>
            </right>
          </binary>
        </condition>
        <then>
          {
          <string>
            &quot;
            <string_content>neg</string_content>
            &quot;
          </string>
          }
        </then>
        <else_if>
          <condition>
            <binary>
              <op>
                <equals/>
                ==
              </op>
              <left>
                <name>n</name>
              </left>
              ==
              <right>
                <int>0</int>
              </right>
            </binary>
          </condition>
          <then>
            {
            <string>
              &quot;
              <string_content>zero</string_content>
              &quot;
            </string>
            }
          </then>
        </else_if>
        <else_if>
          <condition>
            <binary>
              <op>
                <compare>
                  <less/>
                </compare>
                &lt;
              </op>
              <left>
                <name>n</name>
              </left>
              &lt;
              <right>
                <int>10</int>
              </right>
            </binary>
          </condition>
          <then>
            {
            <string>
              &quot;
              <string_content>small</string_content>
              &quot;
            </string>
            }
          </then>
        </else_if>
        <else>
          else {
          <string>
            &quot;
            <string_content>big</string_content>
            &quot;
          </string>
          }
        </else>
      </if>
      }
    </body>
  </function>
  <function>
    <private/>
    fn
    <name>label</name>
    (
    <param>
      <name>n</name>
      :
      <type>
        <name>i32</name>
      </type>
    </param>
    ) -&gt;
    <returns>
      <type>
        <borrowed/>
        &amp;
        <lifetime>
          '
          <name>static</name>
        </lifetime>
        <type>
          <name>str</name>
        </type>
      </type>
    </returns>
    <body>
      {
      <if>
        if
        <condition>
          <binary>
            <op>
              <compare>
                <greater/>
              </compare>
              &gt;
            </op>
            <left>
              <name>n</name>
            </left>
            &gt;
            <right>
              <int>0</int>
            </right>
          </binary>
        </condition>
        <then>
          {
          <string>
            &quot;
            <string_content>positive</string_content>
            &quot;
          </string>
          }
        </then>
        <else>
          else {
          <string>
            &quot;
            <string_content>non-positive</string_content>
            &quot;
          </string>
          }
        </else>
      </if>
      }
    </body>
  </function>
</file>
