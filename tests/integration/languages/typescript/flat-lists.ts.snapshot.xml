<?xml version="1.0" encoding="UTF-8"?>
<program>
  <comment>// Principle #12: parameters / arguments / generics render as flat siblings,</comment>
  <comment>// not nested &lt;parameters&gt;&lt;parameter/&gt;&lt;/parameters&gt; wrappers. Each sibling</comment>
  <comment>// carries a field=&quot;...&quot; attribute for grouping in queries.</comment>
  <function>
    function
    <name>first</name>
    <generics>
      &lt;
      <generic>
        <name>T</name>
      </generic>
      ,
      <generic>
        <name>U</name>
      </generic>
      &gt;
    </generics>
    (
    <param>
      <required/>
      <name>a</name>
      :
      <type>
        <name>T</name>
      </type>
    </param>
    ,
    <param>
      <required/>
      <name>b</name>
      :
      <type>
        <name>U</name>
      </type>
    </param>
    ,
    <param>
      <required/>
      <name>c</name>
      :
      <type>
        <name>number</name>
      </type>
    </param>
    )
    <returns>
      :
      <type>
        <name>T</name>
      </type>
    </returns>
    <body>
      <block>
        {
        <return>
          return
          <name>a</name>
          ;
        </return>
        }
      </block>
    </body>
  </function>
  <call>
    <callee>
      <name>first</name>
    </callee>
    &lt;
    <type>
      <name>string</name>
    </type>
    ,
    <type>
      <name>number</name>
    </type>
    &gt;(
    <string>&quot;x&quot;</string>
    ,
    <number>1</number>
    ,
    <number>2</number>
    )
  </call>
  ;
</program>
