<?xml version="1.0" encoding="UTF-8"?>
<program>
  <comment>// Principle #14: type references wrap their name in a &lt;name&gt; child.</comment>
  <comment>// Every &lt;type&gt; element should contain &lt;name&gt;X&lt;/name&gt;, not bare text.</comment>
  <comment>// Covers: plain types, generic types, base-class/implements, function types.</comment>
  <alias>
    type
    <name>Id</name>
    =
    <type>
      <name>number</name>
    </type>
    ;
  </alias>
  <alias>
    type
    <name>Handler</name>
    =
    <type>
      <function/>
      (
      <param>
        <required/>
        <name>x</name>
        :
        <type>
          <name>number</name>
        </type>
      </param>
      ) =&gt;
      <returns>
        <type>
          <name>void</name>
        </type>
      </returns>
    </type>
    ;
  </alias>
  <alias>
    type
    <name>Box</name>
    <generics>
      &lt;
      <generic>
        <name>T</name>
      </generic>
      &gt;
    </generics>
    =
    <type>
      <generic/>
      <name>Array</name>
      &lt;
      <type>
        <name>T</name>
      </type>
      &gt;
    </type>
    ;
  </alias>
  <class>
    class
    <name>Animal</name>
    <body>{}</body>
  </class>
  <interface>
    interface
    <name>Barker</name>
    <body>
      {
      <method_signature>
        <name>bark</name>
        ()
        <returns>
          :
          <type>
            <name>void</name>
          </type>
        </returns>
      </method_signature>
      ; }
    </body>
  </interface>
  <class>
    class
    <name>Dog</name>
    <extends>
      extends
      <type>
        <name>Animal</name>
      </type>
    </extends>
    <implements>
      implements
      <type>
        <name>Barker</name>
      </type>
    </implements>
    <body>
      {
      <method>
        <name>bark</name>
        ()
        <returns>
          :
          <type>
            <name>void</name>
          </type>
        </returns>
        <body>
          <block>{}</block>
        </body>
      </method>
      }
    </body>
  </class>
</program>
