<?xml version="1.0" encoding="UTF-8"?>
<program>
  <comment>// async / generator lifted to empty markers on &lt;function&gt; and &lt;method&gt;.</comment>
  <comment>// Exhaustive (Principle #9 ish): every function element carries either</comment>
  <comment>// neither or the applicable markers — &lt;async/&gt; and/or &lt;generator/&gt;.</comment>
  <function>
    <async/>
    async function
    <name>fetchOne</name>
    ()
    <returns>
      :
      <type>
        <generic/>
        <name>Promise</name>
        &lt;
        <type>
          <name>number</name>
        </type>
        &gt;
      </type>
    </returns>
    <body>
      <block>
        {
        <return>
          return
          <number>1</number>
          ;
        </return>
        }
      </block>
    </body>
  </function>
  <function>
    <generator/>
    function*
    <name>counter</name>
    ()
    <returns>
      :
      <type>
        <generic/>
        <name>Generator</name>
        &lt;
        <type>
          <name>number</name>
        </type>
        &gt;
      </type>
    </returns>
    <body>
      <block>
        {
        <yield>
          yield
          <number>1</number>
        </yield>
        ; }
      </block>
    </body>
  </function>
  <function>
    <async/>
    <generator/>
    async function*
    <name>stream</name>
    ()
    <returns>
      :
      <type>
        <generic/>
        <name>AsyncGenerator</name>
        &lt;
        <type>
          <name>number</name>
        </type>
        &gt;
      </type>
    </returns>
    <body>
      <block>
        {
        <yield>
          yield
          <number>1</number>
        </yield>
        ; }
      </block>
    </body>
  </function>
  <class>
    class
    <name>Service</name>
    <body>
      {
      <method>
        <async/>
        async
        <name>load</name>
        ()
        <returns>
          :
          <type>
            <generic/>
            <name>Promise</name>
            &lt;
            <type>
              <name>void</name>
            </type>
            &gt;
          </type>
        </returns>
        <body>
          <block>{}</block>
        </body>
      </method>
      <method>
        <generator/>
        *
        <name>keys</name>
        ()
        <returns>
          :
          <type>
            <generic/>
            <name>Generator</name>
            &lt;
            <type>
              <name>string</name>
            </type>
            &gt;
          </type>
        </returns>
        <body>
          <block>
            {
            <yield>
              yield
              <string>&quot;a&quot;</string>
            </yield>
            ; }
          </block>
        </body>
      </method>
      }
    </body>
  </class>
</program>
