<?xml version="1.0" encoding="UTF-8"?>
<program>
  <comment>// Conditional shape: `else if` chains collapse to flat &lt;else_if&gt; siblings of</comment>
  <comment>// &lt;if&gt;; ternary expression keeps &lt;then&gt;/&lt;else&gt; wrappers via surgical field</comment>
  <comment>// wrap (not via the global alternative-&gt;else wrap that was dropped).</comment>
  <function>
    function
    <name>classify</name>
    (
    <param>
      <required/>
      <name>n</name>
      :
      <type>
        <name>number</name>
      </type>
    </param>
    )
    <returns>
      :
      <type>
        <name>string</name>
      </type>
    </returns>
    <body>
      <block>
        {
        <if>
          if
          <condition>
            <parenthesized_expression>
              (
              <binary>
                <op>
                  <compare>
                    <less/>
                  </compare>
                  &lt;
                </op>
                <left>
                  <name>n</name>
                </left>
                &lt;
                <right>
                  <number>0</number>
                </right>
              </binary>
              )
            </parenthesized_expression>
          </condition>
          <then>
            <block>
              {
              <return>
                return
                <string>&quot;neg&quot;</string>
                ;
              </return>
              }
            </block>
          </then>
          <else_if>
            <condition>
              <parenthesized_expression>
                (
                <binary>
                  <op>
                    <equals>
                      <strict/>
                    </equals>
                    ===
                  </op>
                  <left>
                    <name>n</name>
                  </left>
                  ===
                  <right>
                    <number>0</number>
                  </right>
                </binary>
                )
              </parenthesized_expression>
            </condition>
            <then>
              <block>
                {
                <return>
                  return
                  <string>&quot;zero&quot;</string>
                  ;
                </return>
                }
              </block>
            </then>
          </else_if>
          <else_if>
            <condition>
              <parenthesized_expression>
                (
                <binary>
                  <op>
                    <compare>
                      <less/>
                    </compare>
                    &lt;
                  </op>
                  <left>
                    <name>n</name>
                  </left>
                  &lt;
                  <right>
                    <number>10</number>
                  </right>
                </binary>
                )
              </parenthesized_expression>
            </condition>
            <then>
              <block>
                {
                <return>
                  return
                  <string>&quot;small&quot;</string>
                  ;
                </return>
                }
              </block>
            </then>
          </else_if>
          <else>
            else
            <block>
              {
              <return>
                return
                <string>&quot;big&quot;</string>
                ;
              </return>
              }
            </block>
          </else>
        </if>
        }
      </block>
    </body>
  </function>
  <variable>
    <const/>
    const
    <name>label</name>
    =
    <value>
      <lambda>
        (
        <param>
          <required/>
          <name>n</name>
          :
          <type>
            <name>number</name>
          </type>
        </param>
        ) =&gt;
        <body>
          <ternary>
            <condition>
              <binary>
                <op>
                  <compare>
                    <greater/>
                  </compare>
                  &gt;
                </op>
                <left>
                  <name>n</name>
                </left>
                &gt;
                <right>
                  <number>0</number>
                </right>
              </binary>
            </condition>
            ?
            <then>
              <string>&quot;positive&quot;</string>
            </then>
            :
            <else>
              <string>&quot;non-positive&quot;</string>
            </else>
          </ternary>
        </body>
      </lambda>
    </value>
    ;
  </variable>
</program>
