<?xml version="1.0" encoding="UTF-8"?>
<program>
  <comment>// Property accessor methods (`get foo()` / `set foo(v)`) carry a</comment>
  <comment>// &lt;get/&gt; or &lt;set/&gt; marker on the &lt;method&gt;, so //method[get] picks</comment>
  <comment>// them out uniformly regardless of body shape. Mirrors C#'s</comment>
  <comment>// accessor-flattening fixture.</comment>
  <class>
    class
    <name>Counter</name>
    <body>
      {
      <field>
        <accessibility_modifier>private</accessibility_modifier>
        <name>_value</name>
        =
        <value>
          <number>0</number>
        </value>
      </field>
      ;
      <method>
        <get/>
        get
        <name>value</name>
        ()
        <returns>
          :
          <type>
            <name>number</name>
          </type>
        </returns>
        <body>
          <block>
            {
            <return>
              return
              <member>
                <object>
                  <this>this</this>
                </object>
                .
                <property>
                  <name>_value</name>
                </property>
              </member>
              ;
            </return>
            }
          </block>
        </body>
      </method>
      <method>
        <set/>
        set
        <name>value</name>
        (
        <param>
          <required/>
          <name>v</name>
          :
          <type>
            <name>number</name>
          </type>
        </param>
        )
        <body>
          <block>
            {
            <assign>
              <op>=</op>
              <left>
                <member>
                  <object>
                    <this>this</this>
                  </object>
                  .
                  <property>
                    <name>_value</name>
                  </property>
                </member>
              </left>
              =
              <right>
                <name>v</name>
              </right>
            </assign>
            ;
    }
          </block>
        </body>
      </method>
      <method>
        <get/>
        static get
        <name>singleton</name>
        ()
        <returns>
          :
          <type>
            <name>Counter</name>
          </type>
        </returns>
        <body>
          <block>
            {
            <return>
              return
              <new>
                new
                <name>Counter</name>
                ()
              </new>
              ;
            </return>
            }
          </block>
        </body>
      </method>
      }
    </body>
  </class>
</program>
