<?xml version="1.0" encoding="UTF-8"?>
<file>
  <comment>// Principle #12: parameter / argument / field lists flatten. Each</comment>
  <comment>// parameter / argument / struct field is a direct sibling with a</comment>
  <comment>// field attribute, no &lt;parameters&gt; / &lt;argument_list&gt; wrapper.</comment>
  <package>
    package
    <name>main</name>
  </package>
  <function>
    <exported/>
    func
    <name>First</name>
    (
    <param>
      <name>a</name>
      <type>
        <name>string</name>
      </type>
    </param>
    ,
    <param>
      <name>b</name>
      <type>
        <name>int</name>
      </type>
    </param>
    ,
    <param>
      <name>c</name>
      <type>
        <name>bool</name>
      </type>
    </param>
    )
    <returns>
      <type>
        <name>string</name>
      </type>
    </returns>
    <body>
      {
      <return>
        return
        <name>a</name>
      </return>
      }
    </body>
  </function>
  <function>
    <exported/>
    func
    <name>Caller</name>
    ()
    <body>
      {
      <call>
        <name>First</name>
        (
        <string>&quot;x&quot;</string>
        ,
        <int>1</int>
        ,
        <true>true</true>
        )
      </call>
      }
    </body>
  </function>
  <type>
    <exported/>
    type
    <name>Config</name>
    <struct>
      struct {
      <field>
        <name>Host</name>
        <type>
          <name>string</name>
        </type>
      </field>
      <field>
        <name>Port</name>
        <type>
          <name>int</name>
        </type>
      </field>
      <field>
        <name>Tls</name>
        <type>
          <name>bool</name>
        </type>
      </field>
      }
    </struct>
  </type>
</file>
