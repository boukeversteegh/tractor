<?xml version="1.0" encoding="UTF-8"?>
<file>
  <comment>// Conditional shape: flat &lt;if&gt;/&lt;else_if&gt;/&lt;else&gt;. Go has no ternary.</comment>
  <package>
    package
    <name>main</name>
  </package>
  <function>
    <exported/>
    func
    <name>Classify</name>
    (
    <param>
      <name>n</name>
      <type>
        <name>int</name>
      </type>
    </param>
    )
    <returns>
      <type>
        <name>string</name>
      </type>
    </returns>
    <body>
      {
      <if>
        if
        <condition>
          <binary>
            <op>
              <compare>
                <less/>
              </compare>
              &lt;
            </op>
            <left>
              <name>n</name>
            </left>
            &lt;
            <right>
              <int>0</int>
            </right>
          </binary>
        </condition>
        <then>
          {
          <return>
            return
            <string>&quot;neg&quot;</string>
          </return>
          }
        </then>
        else
        <if>
          if
          <condition>
            <binary>
              <op>
                <equals/>
                ==
              </op>
              <left>
                <name>n</name>
              </left>
              ==
              <right>
                <int>0</int>
              </right>
            </binary>
          </condition>
          <then>
            {
            <return>
              return
              <string>&quot;zero&quot;</string>
            </return>
            }
          </then>
          else
          <if>
            if
            <condition>
              <binary>
                <op>
                  <compare>
                    <less/>
                  </compare>
                  &lt;
                </op>
                <left>
                  <name>n</name>
                </left>
                &lt;
                <right>
                  <int>10</int>
                </right>
              </binary>
            </condition>
            <then>
              {
              <return>
                return
                <string>&quot;small&quot;</string>
              </return>
              }
            </then>
            else {
            <return>
              return
              <string>&quot;big&quot;</string>
            </return>
            }
          </if>
        </if>
      </if>
      }
    </body>
  </function>
</file>
