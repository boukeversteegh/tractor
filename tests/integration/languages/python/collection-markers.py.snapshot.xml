<?xml version="1.0" encoding="UTF-8"?>
<module>
  <comment># Python collection literals unify by produced type. &lt;list&gt;, &lt;dict&gt;, &lt;set&gt;</comment>
  <comment># carry exhaustive &lt;literal/&gt; or &lt;comprehension/&gt; markers so queries can</comment>
  <comment># distinguish `[x for x in xs]` from `[1, 2, 3]` without kind-specific</comment>
  <comment># element names like list_comprehension vs list.</comment>
  <assign>
    <left>
      <name>nums</name>
    </left>
    =
    <right>
      <list>
        <literal/>
        [
        <int>1</int>
        ,
        <int>2</int>
        ,
        <int>3</int>
        ]
      </list>
    </right>
  </assign>
  <comment># list + &lt;literal/&gt;</comment>
  <assign>
    <left>
      <name>squares</name>
    </left>
    =
    <right>
      <list>
        <comprehension/>
        [
        <body>
          <binary>
            <op>
              <multiply/>
              *
            </op>
            <left>
              <name>x</name>
            </left>
            *
            <right>
              <name>x</name>
            </right>
          </binary>
        </body>
        <for>
          for
          <left>
            <name>x</name>
          </left>
          in
          <right>
            <name>nums</name>
          </right>
        </for>
        ]
      </list>
    </right>
  </assign>
  <comment># list + &lt;comprehension/&gt;</comment>
  <assign>
    <left>
      <name>pairs</name>
    </left>
    =
    <right>
      <dict>
        <literal/>
        {
        <pair>
          <string>
            <string_start>&quot;</string_start>
            <string_content>a</string_content>
            <string_end>&quot;</string_end>
          </string>
          :
          <value>
            <int>1</int>
          </value>
        </pair>
        ,
        <pair>
          <string>
            <string_start>&quot;</string_start>
            <string_content>b</string_content>
            <string_end>&quot;</string_end>
          </string>
          :
          <value>
            <int>2</int>
          </value>
        </pair>
        }
      </dict>
    </right>
  </assign>
  <comment># dict + &lt;literal/&gt;</comment>
  <assign>
    <left>
      <name>inverted</name>
    </left>
    =
    <right>
      <dict>
        <comprehension/>
        {
        <body>
          <pair>
            <name>v</name>
            :
            <value>
              <name>k</name>
            </value>
          </pair>
        </body>
        <for>
          for
          <left>
            <name>k</name>
            ,
            <name>v</name>
          </left>
          in
          <right>
            <call>
              <member>
                <name>pairs</name>
                .
                <name>items</name>
              </member>
              ()
            </call>
          </right>
        </for>
        }
      </dict>
    </right>
  </assign>
  <comment># dict + &lt;comprehension/&gt;</comment>
  <assign>
    <left>
      <name>unique</name>
    </left>
    =
    <right>
      <set>
        <literal/>
        {
        <int>1</int>
        ,
        <int>2</int>
        ,
        <int>3</int>
        }
      </set>
    </right>
  </assign>
  <comment># set + &lt;literal/&gt;</comment>
  <assign>
    <left>
      <name>uniq_sq</name>
    </left>
    =
    <right>
      <set>
        <comprehension/>
        {
        <body>
          <binary>
            <op>
              <multiply/>
              *
            </op>
            <left>
              <name>x</name>
            </left>
            *
            <right>
              <name>x</name>
            </right>
          </binary>
        </body>
        <for>
          for
          <left>
            <name>x</name>
          </left>
          in
          <right>
            <name>nums</name>
          </right>
        </for>
        }
      </set>
    </right>
  </assign>
  <comment># set + &lt;comprehension/&gt;</comment>
  <assign>
    <left>
      <name>gen</name>
    </left>
    =
    <right>
      <generator>
        (
        <body>
          <name>x</name>
        </body>
        <for>
          for
          <left>
            <name>x</name>
          </left>
          in
          <right>
            <name>nums</name>
          </right>
        </for>
        )
      </generator>
    </right>
  </assign>
  <comment># generator + &lt;comprehension/&gt;</comment>
</module>
