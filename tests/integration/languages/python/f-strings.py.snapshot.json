{
  "$type": "module",
  "children": [
    {
      "comment": "# F-strings render as <string> with interpolation children and bare"
    },
    {
      "comment": "# literal text in between (Principle #12: string_start / string_content /"
    },
    {
      "comment": "# string_end grammar wrappers are flattened — they carry no semantic"
    },
    {
      "comment": "# beyond their text value). Plain strings collapse to a text-only"
    },
    {
      "comment": "# <string> element."
    },
    {
      "comment": "#"
    },
    {
      "comment": "# Query: //string/interpolation/name='age' finds every interpolation of"
    },
    {
      "comment": "# the `age` variable regardless of the surrounding literal text."
    },
    {
      "$type": "assign",
      "left": {
        "name": "plain"
      },
      "right": {
        "string": "\"hello\""
      }
    },
    {
      "$type": "assign",
      "left": {
        "name": "greeting"
      },
      "right": {
        "string": {
          "children": [
            {
              "$type": "interpolation",
              "expression": "name"
            }
          ]
        }
      }
    },
    {
      "$type": "assign",
      "left": {
        "name": "status"
      },
      "right": {
        "string": {
          "children": [
            {
              "$type": "interpolation",
              "expression": "name"
            },
            {
              "$type": "interpolation",
              "expression": "age"
            }
          ]
        }
      }
    }
  ]
}