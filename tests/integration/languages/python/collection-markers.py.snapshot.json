{
  "$type": "module",
  "children": [
    {
      "comment": "# Python collection literals unify by produced type. <list>, <dict>, <set>"
    },
    {
      "comment": "# carry exhaustive <literal/> or <comprehension/> markers so queries can"
    },
    {
      "comment": "# distinguish `[x for x in xs]` from `[1, 2, 3]` without kind-specific"
    },
    {
      "comment": "# element names like list_comprehension vs list."
    },
    {
      "$type": "assign",
      "left": {
        "name": "nums"
      },
      "right": {
        "list": {
          "literal": true,
          "children": [
            {
              "int": "1"
            },
            {
              "int": "2"
            },
            {
              "int": "3"
            }
          ]
        }
      }
    },
    {
      "comment": "# list + <literal/>"
    },
    {
      "$type": "assign",
      "left": {
        "name": "squares"
      },
      "right": {
        "list": {
          "comprehension": true,
          "body": {
            "binary": {
              "left": {
                "name": "x"
              },
              "right": {
                "name": "x"
              },
              "children": [
                {
                  "$type": "op",
                  "multiply": true,
                  "text": "*"
                }
              ]
            }
          },
          "children": [
            {
              "$type": "for",
              "left": {
                "name": "x"
              },
              "right": {
                "name": "nums"
              }
            }
          ]
        }
      }
    },
    {
      "comment": "# list + <comprehension/>"
    },
    {
      "$type": "assign",
      "left": {
        "name": "pairs"
      },
      "right": {
        "dict": {
          "literal": true,
          "children": [
            {
              "$type": "pair",
              "key": {
                "children": [
                  {
                    "string_start": "\""
                  },
                  {
                    "string_content": "a"
                  },
                  {
                    "string_end": "\""
                  }
                ]
              },
              "value": {
                "int": "1"
              }
            },
            {
              "$type": "pair",
              "key": {
                "children": [
                  {
                    "string_start": "\""
                  },
                  {
                    "string_content": "b"
                  },
                  {
                    "string_end": "\""
                  }
                ]
              },
              "value": {
                "int": "2"
              }
            }
          ]
        }
      }
    },
    {
      "comment": "# dict + <literal/>"
    },
    {
      "$type": "assign",
      "left": {
        "name": "inverted"
      },
      "right": {
        "dict": {
          "comprehension": true,
          "body": {
            "pair": {
              "key": "v",
              "value": {
                "name": "k"
              }
            }
          },
          "children": [
            {
              "$type": "for",
              "left": {
                "children": [
                  {
                    "name": "k"
                  },
                  {
                    "name": "v"
                  }
                ]
              },
              "right": {
                "call": {
                  "function": {
                    "object": "pairs",
                    "attribute": "items"
                  }
                }
              }
            }
          ]
        }
      }
    },
    {
      "comment": "# dict + <comprehension/>"
    },
    {
      "$type": "assign",
      "left": {
        "name": "unique"
      },
      "right": {
        "set": {
          "literal": true,
          "children": [
            {
              "int": "1"
            },
            {
              "int": "2"
            },
            {
              "int": "3"
            }
          ]
        }
      }
    },
    {
      "comment": "# set + <literal/>"
    },
    {
      "$type": "assign",
      "left": {
        "name": "uniq_sq"
      },
      "right": {
        "set": {
          "comprehension": true,
          "body": {
            "binary": {
              "left": {
                "name": "x"
              },
              "right": {
                "name": "x"
              },
              "children": [
                {
                  "$type": "op",
                  "multiply": true,
                  "text": "*"
                }
              ]
            }
          },
          "children": [
            {
              "$type": "for",
              "left": {
                "name": "x"
              },
              "right": {
                "name": "nums"
              }
            }
          ]
        }
      }
    },
    {
      "comment": "# set + <comprehension/>"
    },
    {
      "$type": "assign",
      "left": {
        "name": "gen"
      },
      "right": {
        "generator": {
          "body": {
            "name": "x"
          },
          "children": [
            {
              "$type": "for",
              "left": {
                "name": "x"
              },
              "right": {
                "name": "nums"
              }
            }
          ]
        }
      }
    },
    {
      "comment": "# generator + <comprehension/>"
    }
  ]
}