<?xml version="1.0" encoding="UTF-8"?>
<module>
  <comment># Goal #5 (mental model): augmented_assignment unifies with plain</comment>
  <comment># assignment as &lt;assign&gt; plus an &lt;op&gt; child carrying the compound</comment>
  <comment># operator. A single //assign query matches every assignment.</comment>
  <function>
    def
    <name>ops</name>
    ():
    <body>
      <assign>
        <left>
          <name>x</name>
        </left>
        =
        <right>
          <int>0</int>
        </right>
      </assign>
      <assign>
        <op>
          <assign>
            <plus/>
          </assign>
          +=
        </op>
        <left>
          <name>x</name>
        </left>
        +=
        <right>
          <int>1</int>
        </right>
      </assign>
      <assign>
        <op>
          <assign>
            <minus/>
          </assign>
          -=
        </op>
        <left>
          <name>x</name>
        </left>
        -=
        <right>
          <int>2</int>
        </right>
      </assign>
      <assign>
        <op>
          <assign>
            <multiply/>
          </assign>
          *=
        </op>
        <left>
          <name>x</name>
        </left>
        *=
        <right>
          <int>3</int>
        </right>
      </assign>
      <assign>
        <op>//=</op>
        <left>
          <name>x</name>
        </left>
        //=
        <right>
          <int>2</int>
        </right>
      </assign>
      <assign>
        <op>
          <assign>
            <power/>
          </assign>
          **=
        </op>
        <left>
          <name>x</name>
        </left>
        **=
        <right>
          <int>2</int>
        </right>
      </assign>
      <assign>
        <op>
          <assign>
            <bitwise>
              <and/>
            </bitwise>
          </assign>
          &amp;=
        </op>
        <left>
          <name>x</name>
        </left>
        &amp;=
        <right>
          <int>0xFF</int>
        </right>
      </assign>
      <assign>
        <op>
          <assign>
            <bitwise>
              <or/>
            </bitwise>
          </assign>
          |=
        </op>
        <left>
          <name>x</name>
        </left>
        |=
        <right>
          <int>0x10</int>
        </right>
      </assign>
      <assign>
        <op>
          <assign>
            <bitwise>
              <xor/>
            </bitwise>
          </assign>
          ^=
        </op>
        <left>
          <name>x</name>
        </left>
        ^=
        <right>
          <int>0x01</int>
        </right>
      </assign>
      <assign>
        <op>
          <assign>
            <shift>
              <left/>
            </shift>
          </assign>
          &lt;&lt;=
        </op>
        <left>
          <name>x</name>
        </left>
        &lt;&lt;=
        <right>
          <int>1</int>
        </right>
      </assign>
      <assign>
        <op>
          <assign>
            <shift>
              <right/>
            </shift>
          </assign>
          &gt;&gt;=
        </op>
        <left>
          <name>x</name>
        </left>
        &gt;&gt;=
        <right>
          <int>1</int>
        </right>
      </assign>
    </body>
  </function>
</module>
