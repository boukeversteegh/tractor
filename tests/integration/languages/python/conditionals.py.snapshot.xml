<?xml version="1.0" encoding="UTF-8"?>
<module>
  <comment># Conditional shape: `elif` renders as &lt;else_if&gt; (underscore naming per</comment>
  <comment># Principle #1), collapsed as a flat sibling of &lt;if&gt;. Ternary expression</comment>
  <comment># keeps &lt;then&gt;/&lt;else&gt; wrappers via surgical field wrap.</comment>
  <function>
    def
    <name>classify</name>
    (
    <name>n</name>
    ):
    <body>
      <if>
        if
        <condition>
          <compare>
            <op>
              <compare>
                <less/>
              </compare>
              &lt;
            </op>
            <name>n</name>
            &lt;
            <int>0</int>
          </compare>
        </condition>
        :
        <then>
          <return>
            return
            <string>
              <string_start>&quot;</string_start>
              <string_content>neg</string_content>
              <string_end>&quot;</string_end>
            </string>
          </return>
        </then>
        <else_if>
          elif
          <condition>
            <compare>
              <op>
                <equals/>
                ==
              </op>
              <name>n</name>
              ==
              <int>0</int>
            </compare>
          </condition>
          :
          <then>
            <return>
              return
              <string>
                <string_start>&quot;</string_start>
                <string_content>zero</string_content>
                <string_end>&quot;</string_end>
              </string>
            </return>
          </then>
        </else_if>
        <else_if>
          elif
          <condition>
            <compare>
              <op>
                <compare>
                  <less/>
                </compare>
                &lt;
              </op>
              <name>n</name>
              &lt;
              <int>10</int>
            </compare>
          </condition>
          :
          <then>
            <return>
              return
              <string>
                <string_start>&quot;</string_start>
                <string_content>small</string_content>
                <string_end>&quot;</string_end>
              </string>
            </return>
          </then>
        </else_if>
        <else>
          else:
          <body>
            <return>
              return
              <string>
                <string_start>&quot;</string_start>
                <string_content>big</string_content>
                <string_end>&quot;</string_end>
              </string>
            </return>
          </body>
        </else>
      </if>
    </body>
  </function>
  <function>
    def
    <name>label</name>
    (
    <name>n</name>
    ):
    <body>
      <return>
        return
        <ternary>
          <string>
            <string_start>&quot;</string_start>
            <string_content>positive</string_content>
            <string_end>&quot;</string_end>
          </string>
          if
          <compare>
            <op>
              <compare>
                <greater/>
              </compare>
              &gt;
            </op>
            <name>n</name>
            &gt;
            <int>0</int>
          </compare>
          else
          <string>
            <string_start>&quot;</string_start>
            <string_content>non-positive</string_content>
            <string_end>&quot;</string_end>
          </string>
        </ternary>
      </return>
    </body>
  </function>
</module>
