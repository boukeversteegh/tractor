<?xml version="1.0" encoding="UTF-8"?>
<module>
  <comment># Principle #12: `expression_list` (tuple-like return/yield expressions)</comment>
  <comment># is a pure grouping node; drop it so the expressions become direct</comment>
  <comment># children of the enclosing &lt;return&gt;/&lt;yield&gt;/&lt;assign&gt;. Parallel with Go.</comment>
  <function>
    def
    <name>pair</name>
    ():
    <body>
      <return>
        return
        <int>1</int>
        ,
        <int>2</int>
      </return>
    </body>
  </function>
  <function>
    def
    <name>triple</name>
    ():
    <body>
      <return>
        return
        <string>
          <string_start>&quot;</string_start>
          <string_content>a</string_content>
          <string_end>&quot;</string_end>
        </string>
        ,
        <string>
          <string_start>&quot;</string_start>
          <string_content>b</string_content>
          <string_end>&quot;</string_end>
        </string>
        ,
        <string>
          <string_start>&quot;</string_start>
          <string_content>c</string_content>
          <string_end>&quot;</string_end>
        </string>
      </return>
    </body>
  </function>
  <function>
    def
    <name>unpack</name>
    ():
    <body>
      <assign>
        <left>
          <name>a</name>
          ,
          <name>b</name>
        </left>
        =
        <right>
          <call>
            <name>pair</name>
            ()
          </call>
        </right>
      </assign>
      <return>
        return
        <binary>
          <op>
            <plus/>
            +
          </op>
          <left>
            <name>a</name>
          </left>
          +
          <right>
            <name>b</name>
          </right>
        </binary>
      </return>
    </body>
  </function>
</module>
