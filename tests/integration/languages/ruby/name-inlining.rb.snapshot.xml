<?xml version="1.0" encoding="UTF-8"?>
<program>
  <comment># Two invariants:</comment>
  <comment>#</comment>
  <comment># 1. Every Ruby `identifier` becomes &lt;name&gt; unconditionally (no</comment>
  <comment>#    type_identifier in Ruby's grammar, so identifiers are always</comment>
  <comment>#    value references). Matches Python / TS / Java / Rust on the</comment>
  <comment>#    value-namespace side (Principle #14).</comment>
  <comment>#</comment>
  <comment># 2. When a &lt;name&gt; wrapper sits inside method / class / module and</comment>
  <comment>#    contains a single identifier, the transform inlines its text</comment>
  <comment>#    directly: &lt;method&gt;&lt;name&gt;foo&lt;/name&gt;… not</comment>
  <comment>#    &lt;method&gt;&lt;name&gt;&lt;identifier&gt;foo&lt;/identifier&gt;&lt;/name&gt;…</comment>
  <class>
    class
    <name>Calculator</name>
    <body>
      <method>
        def
        <name>add</name>
        (
        <name>a</name>
        ,
        <name>b</name>
        )
        <body>
          <binary>
            <left>
              <name>a</name>
            </left>
            +
            <right>
              <name>b</name>
            </right>
          </binary>
        </body>
        end
      </method>
    </body>
    end
  </class>
  <module>
    module
    <name>Utils</name>
    <body>
      <singleton_method>
        def
        <self>self</self>
        .
        <name>
          <name>greet</name>
        </name>
        (
        <name>name</name>
        )
        <body>
          <string>
            &quot;
            <string_content>hi, </string_content>
            <interpolation>
              #{
              <name>name</name>
              }
            </interpolation>
            &quot;
          </string>
        </body>
        end
      </singleton_method>
    </body>
    end
  </module>
</program>
