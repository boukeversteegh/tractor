<?xml version="1.0" encoding="UTF-8"?>
<program>
  <comment># Ruby's nested elsif / else chain collapses to flat &lt;else_if&gt; / &lt;else&gt;</comment>
  <comment># siblings of &lt;if&gt; (post-walk collapse_else_if_chain). `elsif` is</comment>
  <comment># renamed to &lt;else_if&gt; (underscore per Principle #1).</comment>
  <method>
    def
    <name>classify</name>
    (
    <identifier>n</identifier>
    )
    <body>
      <if>
        if
        <condition>
          <binary>
            <left>
              <identifier>n</identifier>
            </left>
            &lt;
            <right>
              <int>0</int>
            </right>
          </binary>
        </condition>
        <then>
          <string>
            &quot;
            <string_content>neg</string_content>
            &quot;
          </string>
        </then>
        end
        <else_if>
          elsif
          <condition>
            <binary>
              <left>
                <identifier>n</identifier>
              </left>
              ==
              <right>
                <int>0</int>
              </right>
            </binary>
          </condition>
          <then>
            <string>
              &quot;
              <string_content>zero</string_content>
              &quot;
            </string>
          </then>
        </else_if>
        <else_if>
          elsif
          <condition>
            <binary>
              <left>
                <identifier>n</identifier>
              </left>
              &lt;
              <right>
                <int>10</int>
              </right>
            </binary>
          </condition>
          <then>
            <string>
              &quot;
              <string_content>small</string_content>
              &quot;
            </string>
          </then>
        </else_if>
        <else>
          else
          <string>
            &quot;
            <string_content>big</string_content>
            &quot;
          </string>
        </else>
      </if>
    </body>
    end
  </method>
  <method>
    def
    <name>label</name>
    (
    <identifier>n</identifier>
    )
    <body>
      <conditional>
        <condition>
          <binary>
            <left>
              <identifier>n</identifier>
            </left>
            &gt;
            <right>
              <int>0</int>
            </right>
          </binary>
        </condition>
        ?
        <string>
          &quot;
          <string_content>positive</string_content>
          &quot;
        </string>
        :
        <string>
          &quot;
          <string_content>non-positive</string_content>
          &quot;
        </string>
      </conditional>
    </body>
    end
  </method>
</program>
